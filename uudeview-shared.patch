-
-.c.o:
-	$(CC) -c $(CFLAGS) $(VDEF) $<
-
-uuencode.o:	uuencode.c uudeview.h uuint.h uustring.h fptools.h config.h
-uulib.o:	uulib.c uudeview.h uuint.h uustring.h fptools.h config.h
